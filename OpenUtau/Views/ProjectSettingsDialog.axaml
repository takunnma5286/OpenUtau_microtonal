<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenUtau.App.ViewModels"
        xmlns:c="using:OpenUtau.App.Views"
        Title="{DynamicResource pjsettings.caption}"
        x:Class="OpenUtau.App.Views.ProjectSettingsDialog">
  <Window.Resources>
    <vm:LinearScaleConverter x:Key="ScaleConverter"/>
  </Window.Resources>
  <c:ProjectSettingsView Name="View"/>
</Window>
